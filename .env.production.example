# PodPaaS Production Environment Variables
# Copy this file to .env and fill in the values

# REQUIRED: Set a strong random secret for JWT signing (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Node environment
NODE_ENV=production

# API server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# JWT token expiration (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Database directory
DATA_DIR=/app/data

# Podman socket path
# Rootless: /run/user/1000/podman/podman.sock
# Rootful:  /run/podman/podman.sock
PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# Frontend URL (for CORS — comma-separated for multiple)
FRONTEND_URL=https://paas.yourdomain.com

# Build configuration
BUILD_DIR=/tmp/podman-paas-builds
BUILD_TIMEOUT_MS=600000

# Deploy timeout (15 min default)
DEPLOY_TIMEOUT_MS=900000

# Default resource limits for containers
# Memory in bytes (512MB = 536870912)
DEFAULT_MEMORY_LIMIT=536870912
# CPU cores (1.0 = one full core)
DEFAULT_CPU_LIMIT=1.0

# Podman API timeout
PODMAN_TIMEOUT_MS=15000
