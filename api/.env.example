# PodPaaS API Environment Configuration
# Copy this file to .env and fill in the values

# REQUIRED: JWT Secret for signing tokens (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Node environment
NODE_ENV=development

# Server configuration
PORT=3001
HOST=0.0.0.0

# Database directory
DATA_DIR=./data

# Podman socket path
# Rootless: /run/user/1000/podman/podman.sock (replace 1000 with your UID)
# Rootful:  /run/podman/podman.sock
PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# Frontend URL (for CORS — comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Build configuration
BUILD_DIR=/tmp/podman-paas-builds
BUILD_TIMEOUT_MS=600000  # 10 minutes

# Deploy timeout
DEPLOY_TIMEOUT_MS=900000  # 15 minutes

# Default resource limits for containers (optional)
DEFAULT_MEMORY_LIMIT=536870912  # 512MB
DEFAULT_CPU_LIMIT=1.0

# Podman API timeout
PODMAN_TIMEOUT_MS=15000  # 15 seconds
